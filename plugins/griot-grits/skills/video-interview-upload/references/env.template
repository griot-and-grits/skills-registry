# Griot and Grits — Video Processing Environment
# Copy this file to your video-processing folder and rename it to .env
# Fill in the values for your setup.

# Absolute path to your video-processing folder.
# Set this so you can invoke the skill from any directory.
GNG_VIDEO_DIR=/path/to/your/video-processing

# Path to your YouTube OAuth2 client_secrets.json.
# Defaults to .youtube_credentials/client_secrets.json inside GNG_VIDEO_DIR if not set.
# GNG_YOUTUBE_CREDENTIALS=
