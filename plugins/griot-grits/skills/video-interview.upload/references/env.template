# Griot and Grits — Video Processing Environment
# Copy this file to your video-processing folder and rename it to .env
# Fill in the values for your setup.

# Folder where raw interview video files (.mp4, .mkv) are located.
GNG_VIDEO_INPUT_DIR=/path/to/your/videos

# Folder where transcript files (.txt) are located.
# Defaults to GNG_VIDEO_INPUT_DIR if not set.
# GNG_TRANSCRIPT_DIR=

# Folder where generated metadata files (output/*.md) are saved.
# Defaults to <GNG_VIDEO_INPUT_DIR>/output if not set.
# GNG_OUTPUT_DIR=

# Path to your YouTube OAuth2 client_secrets.json.
# Defaults to .youtube_credentials/client_secrets.json inside GNG_VIDEO_INPUT_DIR if not set.
# GNG_YOUTUBE_CREDENTIALS=
